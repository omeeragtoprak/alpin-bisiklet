# ============================================
# Alpin Bisiklet - Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# Veritabanı
DATABASE_URL="postgresql://user:password@localhost:5432/alpin_bisiklet"

# Better Auth
BETTER_AUTH_SECRET="min-32-karakter-guclu-rastgele-secret-uretiniz"
BETTER_AUTH_URL="http://localhost:3000"

# Uygulama
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Iyzico Ödeme
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Redis (opsiyonel)
REDIS_URL="redis://localhost:6379"

# Mail (Google Workspace SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=koksaltekin@alpinbisiklet.com
SMTP_PASSWORD=google-app-sifreniz
SMTP_FROM="Alpin Bisiklet Admin <koksaltekin@alpinbisiklet.com>"
# Müşteri maillerinde gösterilecek FROM adresi (Google Workspace alias oluşturulursa)
# SMTP_FROM_CUSTOMER="Alpin Bisiklet <noreply@alpinbisiklet.com>"

# Cron (periyodik bülten maili için — rastgele güçlü bir string girin)
CRON_SECRET="rastgele-guclu-cron-secret-buraya"

# Sosyal Medya Linkleri (opsiyonel)
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_TWITTER_URL=""
NEXT_PUBLIC_YOUTUBE_URL=""
